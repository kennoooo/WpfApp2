<Page x:Class="WpfApp2.BuilderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сборка">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="PartsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="10" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип детали" Binding="{Binding TypeName}" Width="1.5*"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Part.name}" Width="3*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Part.price}" Width="1*"/>
                <DataGridTemplateColumn Width="1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Выбрать" Click="SelectPart_Click" Tag="{Binding TypeId}" Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1" Margin="10,10,20,10">
            <TextBlock Text="Итоговая цена:" FontSize="16" Foreground="Gray"/>
            <TextBlock x:Name="TotalPriceTb" Text="0 ₽" FontSize="28" FontWeight="Bold" Margin="0,0,0,30"/>

            <TextBlock Text="Название сборки:"/>
            <TextBox x:Name="BuildNameTb" Margin="0,5,0,15" Padding="5"/>

            <TextBlock Text="Автор сборки:"/>
            <TextBox x:Name="AuthorTb" Margin="0,5,0,30" Padding="5"/>

            <Button Content="Сохранить сборку" Click="SaveBuild_Click" Padding="10" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>